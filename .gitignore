# ── Secrets & credentials ────────────────────────────────────────────────────
# Real env files — never commit these
.env
.env.dev
.env.prod
# service-account key files (e.g. shree-500106-*.json)
*.json
# re-allow package.json and example env templates
!package.json
!*.example

# ── Frontend ─────────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/

# ── Backend ───────────────────────────────────────────────────────────────────
backend/db.sqlite3
backend/*.sqlite3
backend/staticfiles/

# ── Django runtime ───────────────────────────────────────────────────────────
db.sqlite3
*.sqlite3
*.log

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so

# ── Virtual environment ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── VS Code ───────────────────────────────────────────────────────────────────
.vscode/

# ── OS artefacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Build / dist ─────────────────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
