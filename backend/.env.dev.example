# ─────────────────────────────────────────────────────────────────────────────
# backend/.env.dev.example
#
# Copy this file to .env.dev and fill in your local values.
# .env.dev is gitignored — never commit real credentials.
#
#   cp backend/.env.dev.example backend/.env.dev
# ─────────────────────────────────────────────────────────────────────────────

# Django
DJANGO_SECRET_KEY=dev-only-insecure-secret-key-change-me
# DEBUG is always True in dev settings — no need to set it here

# ── Google Sheets (optional in dev — leave blank to skip Sheets sync) ─────────
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SHEETS_WORKSHEET_NAME=IPD
GOOGLE_SHEETS_OPD_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SHEETS_OPD_WORKSHEET_NAME=OPD
GOOGLE_SERVICE_ACCOUNT_FILE=/absolute/path/to/your/service-account.json
