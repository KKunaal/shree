# ─────────────────────────────────────────────────────────────────────────────
# backend/.env.prod.example
#
# These variables are injected by Cloud Run — do NOT create a .env.prod file
# in production.  This file is for documentation only.
#
# Set each value via:
#   gcloud run services update shree-hms \
#     --set-env-vars KEY=VALUE \
#     --set-secrets  KEY=SECRET_NAME:latest
# ─────────────────────────────────────────────────────────────────────────────

# Django
DJANGO_SECRET_KEY=<strong-random-secret>          # Cloud Run env var
DJANGO_ALLOWED_HOSTS=shree-hms-750926008347.asia-south1.run.app

# Cloud SQL PostgreSQL  (injected automatically when Cloud SQL is attached)
DATABASE_URL=postgresql://USER:PASS@/DBNAME?host=/cloudsql/PROJECT:REGION:INSTANCE

# Google Sheets
GOOGLE_SHEETS_SPREADSHEET_ID=<spreadsheet_id>     # Cloud Run env var or secret
GOOGLE_SHEETS_WORKSHEET_NAME=IPD
GOOGLE_SHEETS_OPD_SPREADSHEET_ID=<spreadsheet_id>
GOOGLE_SHEETS_OPD_WORKSHEET_NAME=OPD
GOOGLE_SERVICE_ACCOUNT_JSON=<full JSON content>   # Cloud Run secret (not file path)
