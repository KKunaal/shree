DJANGO_DEBUG=True
DJANGO_SECRET_KEY=your-secret-key-here
# IPD sheet
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SHEETS_WORKSHEET_NAME=IPD
# OPD sheet (same spreadsheet, different tab — set OPD_WORKSHEET_NAME to the actual tab name)
GOOGLE_SHEETS_OPD_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SHEETS_OPD_WORKSHEET_NAME=OPD
GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/your/service-account.json
